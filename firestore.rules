rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /movies/{movieId}/userRatings/{userId} {
      allow read: if true;
      allow delete: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId
                            && request.resource.data.rating is number
                            && request.resource.data.rating >= 1.0
                            && request.resource.data.rating <= 5.0
                            && request.resource.data.reviewText is string
                            && request.resource.data.reviewText.size() <= 1000
                            && request.resource.data.username is string
                            && request.resource.data.username.size() <= 100
                            && request.resource.data.updatedAt is timestamp;
    }
  }
}
